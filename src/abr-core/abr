cmd_listnations() {
    print_header
    echo -e "${GREEN}🌍 AFRICAN NATIONS - PRE-MINE ALLOCATIONS${NC}"
    echo "============================================================"
    printf "%-4s %-6s %-24s %-20s %-18s %-15s %-10s\n" "Flag" "Code" "Nation" "Capital" "Region" "Allocation" "Population"
    echo "------------------------------------------------------------------------------------------------------------------------"

    local total=0
    for code in NG ZA EG KE ET GH MA AO TZ CD DZ UG SD CI CM ZW ZM SN ML BF MW BJ GN RW BI TG SL LR; do
        IFS=':' read -r name capital region amount pop <<< "${NATIONS[$code]}"
        case $code in
            NG) flag="🇳🇬" ;; ZA) flag="🇿🇦" ;; EG) flag="🇪🇬" ;; KE) flag="🇰🇪" ;; ET) flag="🇪🇹" ;;
            GH) flag="🇬🇭" ;; MA) flag="🇲🇦" ;; AO) flag="🇦🇴" ;; TZ) flag="🇹🇿" ;; CD) flag="🇨🇩" ;;
            DZ) flag="🇩🇿" ;; UG) flag="🇺🇬" ;; SD) flag="🇸🇩" ;; CI) flag="🇨🇮" ;; CM) flag="🇨🇲" ;;
            ZW) flag="🇿🇼" ;; ZM) flag="🇿🇲" ;; SN) flag="🇸🇳" ;; ML) flag="🇲🇱" ;; BF) flag="🇧🇫" ;;
            MW) flag="🇲🇼" ;; BJ) flag="🇧🇯" ;; GN) flag="🇬🇳" ;; RW) flag="🇷🇼" ;; BI) flag="🇧🇮" ;;
            TG) flag="🇹🇬" ;; SL) flag="🇸🇱" ;; LR) flag="🇱🇷" ;;
            *) flag="🏁" ;;
        esac
        printf "%-4s %-6s %-24s %-20s %-18s %'13d ABR %-10s\n" "$flag" "$code" "$name" "$capital" "$region" "$amount" "$pop"
        total=$((total + amount))
    done

    echo "------------------------------------------------------------------------------------------------------------------------"
    printf "Total Nations: 54 | Total Allocation: %'d ABR\n" "$total"
    echo "============================================================"
}

cmd_getnation() {
    local code="$1"
    if [ -z "$code" ]; then
        echo -e "${RED}❌ Error: Nation code required (e.g., NG, ZA, KE)${NC}"
        return 1
    fi
    code=$(echo "$code" | tr '[:lower:]' '[:upper:]')
    if [ -z "${NATIONS[$code]}" ]; then
        echo -e "${RED}❌ Error: Nation '$code' not found${NC}"
        return 1
    fi
    IFS=':' read -r name capital region amount pop <<< "${NATIONS[$code]}"
    print_header
    echo -e "${GREEN}🏛️  NATION DETAILS: $name${NC}"
    echo "=================================="
    echo -e "Code:      ${YELLOW}$code${NC}"
    echo -e "Capital:   ${WHITE}$capital${NC}"
    echo -e "Region:    ${CYAN}$region${NC}"
    echo -e "Allocation:${GREEN}$amount ABR${NC}"
    echo -e "Population:${PURPLE}$pop${NC}"
    echo "============================================================"
}

cmd_getnationalloc() {
    local code="$1"
    if [ -z "$code" ]; then
        echo -e "${RED}❌ Error: Nation code required${NC}"
        return 1
    fi
    code=$(echo "$code" | tr '[:lower:]' '[:upper:]')
    if [ -z "${NATIONS[$code]}" ]; then
        echo -e "${RED}❌ Error: Nation '$code' not found${NC}"
        return 1
    fi
    IFS=':' read -r name capital region amount pop <<< "${NATIONS[$code]}"
    echo "$amount"
}

cmd_getnationsupply() {
    local total=0
    for nation in "${NATIONS[@]}"; do
        IFS=':' read -r name capital region amount pop <<< "$nation"
        total=$((total + amount))
    done
    echo -e "${GREEN}💰 Total Supply Allocated to Nations: ${YELLOW}$total ABR${NC}"
}

