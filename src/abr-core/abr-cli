cmd_getwhaletier() {
    local tier="$1"
    if [ -z "$tier" ]; then
        echo -e "${RED}❌ Error: Tier required (tier_1, tier_2, tier_3)${NC}"
        return 1
    fi
    
    print_header
    echo -e "${CYAN}🐋 WHALE INVESTORS - TIER $tier${NC}"
    echo "============================================================"
    printf "%-12s %-30s %-15s %-15s\n" "ID" "Investor" "Amount" "Country"
    echo "----------------------------------------------------------------------"
    
    local total=0
    for id in "${!WHALES[@]}"; do
        IFS=':' read -r name t amount address country vesting <<< "${WHALES[$id]}"
        if [ "$t" = "$tier" ]; then
            printf "%-12s %-30s %'13d ABR %-15s\n" "$id" "$name" "$amount" "$country"
            total=$((total + amount))
        fi
    done
    
    echo "----------------------------------------------------------------------"
    printf "Tier Total: %'d ABR\n" "$total"
    echo "============================================================"
}

