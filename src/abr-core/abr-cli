    echo "============================================================"
    echo ""
    echo -e "${YELLOW}🔷 BLOCKCHAIN COMMANDS:${NC}"
    echo "  getinfo              - Get network information"
    echo "  getblockcount        - Get current block height"
    echo "  getblockhash <height> - Get block hash at height"
    echo "  getbestblockhash     - Get best block hash"
    echo "  getdifficulty        - Get mining difficulty"
    echo ""
    echo -e "${GREEN}🔷 GENESIS COMMANDS:${NC}"
    echo "  getgenesis           - Show genesis block details"
    echo "  getgenesistx         - Get genesis transaction"
    echo "  getgenesisaddress    - Get genesis address"
    echo "  getgenesismessage    - Get genesis message"
    echo ""
    echo -e "${PURPLE}🔷 NATION COMMANDS:${NC}"
    echo "  listnations          - List all 54 African nations"
    echo "  getnation <code>     - Get specific nation details"
    echo "  getnationalloc <code> - Get nation allocation"
    echo "  getnationsupply      - Total supply allocated to nations"
    echo ""
    echo -e "${CYAN}🔷 WHALE COMMANDS:${NC}"
    echo "  listwhales           - List whale investors"
    echo "  getwhale <id>        - Get specific whale investor"
    echo "  getwhaletier <tier>  - List whales by tier"
