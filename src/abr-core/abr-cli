# ============================================================
# MAIN
# ============================================================

COMMAND="$1"
shift 2>/dev/null

case "$COMMAND" in
    # Blockchain commands
    getinfo) cmd_getinfo ;;
    getblockcount) cmd_getblockcount ;;
    getblockhash) cmd_getblockhash "$1" ;;
    getbestblockhash) cmd_getbestblockhash ;;
    getdifficulty) cmd_getdifficulty ;;
    
    # Genesis commands
    getgenesis) cmd_getgenesis ;;
    getgenesistx) cmd_getgenesistx ;;
    getgenesisaddress) cmd_getgenesisaddress ;;
    getgenesismessage) cmd_getgenesismessage ;;
    
    # Nation commands
    listnations) cmd_listnations ;;
    getnation) cmd_getnation "$1" ;;
    getnationalloc) cmd_getnationalloc "$1" ;;
    getnationsupply) cmd_getnationsupply ;;
    
    # Whale commands
    listwhales) cmd_listwhales ;;
    getwhale) cmd_getwhale "$1" ;;
    getwhaletier) cmd_getwhaletier "$1" ;;
    
    # Address commands
    getaddressbalance) cmd_getaddressbalance "$1" ;;
    gettopaddresses) cmd_gettopaddresses ;;
    
    # Other
    version) echo "ABR Protocol CLI v2.0.0" ;;
    help|--help|-h) cmd_help ;;
    
    # Default
    "")
        cmd_help
        ;;
    *)
        echo -e "${RED}❌ Unknown command: $COMMAND${NC}"
        echo "Use 'abr help' for available commands"
        exit 1
        ;;
esac
