cmd_getwhale() {
    local id="$1"
    if [ -z "$id" ]; then
        echo -e "${RED}❌ Error: Whale ID required (e.g., WHALE001)${NC}"
        return 1
    fi
    
    id=$(echo "$id" | tr '[:lower:]' '[:upper:]')
    
    if [ -z "${WHALES[$id]}" ]; then
        echo -e "${RED}❌ Error: Whale '$id' not found${NC}"
        return 1
