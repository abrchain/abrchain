#!/usr/bin/env python3
"""
ABR Protocol Client - Shared library for all Python projects
"""
import requests
import json
from typing import Optional, Dict, Any

class ABRProtocolClient:
    GENESIS_HASH = "3da515799179d2f8bf0fbb86167bef332ea2bbb972631922b6ca98ce64aff3a7"
    
    def __init__(self, server_url: str = "http://localhost:8345"):
        self.server_url = server_url
        
    def get_protocol_info(self) -> Dict[str, Any]:
        return self._get("/protocol/info")
    
    def get_protocol_hash(self) -> str:
        data = self._get("/protocol/hash")
        return data.get("protocol_hash", self.GENESIS_HASH)
    
    def validate_address(self, address: str) -> Dict[str, Any]:
        try:
            response = requests.get(f"{self.server_url}/protocol/validate/{address}")
            return response.json()
        except:
            return {"valid": False}
    
    def _get(self, endpoint: str) -> Dict[str, Any]:
        try:
            response = requests.get(f"{self.server_url}{endpoint}", timeout=5)
            return response.json()
        except:
            return {}
